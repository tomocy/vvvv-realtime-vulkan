{
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "files.trimFinalNewlines": true,
    "files.associations": {
        ".clang-format": "yaml",
        ".clang-tidy": "yaml",
        ".clangd": "yaml",
    },
    "clangd.path": "/usr/bin/clangd-18",
    "clangd.arguments": [
        "--enable-config",
        "--clang-tidy",
    ]
}
